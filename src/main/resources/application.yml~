server:
  port: 8085

spring:
  application:
    name: product
  datasource:
    url: jdbc:postgresql://${DB_HOST:localhost}:5432/product_service_db
    username: postgres
    password: password
    driver-class-name: org.postgresql.Driver
  jpa:
    hibernate:
      ddl-auto: create-drop
    show-sql: true
    properties:
      hibernate:
        format_sql: true
    database: postgresql
    database-platform: org.hibernate.dialect.PostgreSQLDialect
